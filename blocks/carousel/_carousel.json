                "image": "/content/dam/wknd-universal/images/placeholder-black.png",
                "text": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus blandit nunc a felis dapibus, et placerat lorem ullamcorper. Sed ut perspiciatis unde omnis iste natus error sit voluptatem.</p>"
              }
