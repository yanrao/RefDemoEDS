{
  "definitions": [
    {
      "title": "Download List",
      "id": "download-list",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Download List",
              "model": "download-list",
              "key-value": true
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "download-list",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "title",
          "label": "Section Title",
          "value": "Download Center"
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "assetFolder",
          "label": "Asset Folder",
          "description": "DAM folder to list. All files inside this folder are listed automatically. Leave empty if you want to pick individual files below.",
          "validation": {
            "rootPath": "/content/dam"
          }
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "individualAssets",
          "label": "Individual Files",
          "description": "Pick one or more files from AEM Assets — can span multiple folders. When set, this takes priority over Asset Folder.",
          "multi": true
        },
        {
          "component": "multiselect",
          "valueType": "string",
          "name": "fileTypes",
          "label": "File Types",
          "description": "MIME type prefixes or extensions to include (e.g. application/pdf, pdf, doc, xls). Leave empty to include all.",
          "value": "",
          "options": [
            { "name": "PDF", "value": "pdf" },
            { "name": "Word (.doc/.docx)", "value": "doc" },
            { "name": "Excel (.xls/.xlsx)", "value": "xls" },
            { "name": "PowerPoint (.ppt/.pptx)", "value": "ppt" },
            { "name": "Images", "value": "image" },
            { "name": "Video", "value": "video" },
            { "name": "Audio", "value": "audio" },
            { "name": "Archive (.zip)", "value": "zip" }
          ]
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "sortBy",
          "label": "Sort By",
          "value": "name",
          "options": [
            { "name": "Name (A→Z)", "value": "name" },
            { "name": "Name (Z→A)", "value": "name-desc" },
            { "name": "Newest first", "value": "modified-desc" },
            { "name": "Oldest first", "value": "modified" },
            { "name": "Largest first", "value": "size-desc" },
            { "name": "Smallest first", "value": "size" }
          ]
        },
        {
          "component": "text",
          "valueType": "number",
          "name": "limit",
          "label": "Max Items",
          "description": "0 = no limit",
          "value": "0"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "downloadLabel",
          "label": "Download Button Label",
          "description": "Optional text next to the download icon. Leave empty to show only the icon."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "bgColor",
          "label": "Background Color",
          "description": "CSS color for the block background (hex, rgb, or var). Example: #ffffff",
          "value": "#ffffff"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "textColor",
          "label": "Text Color",
          "description": "CSS color for the text (hex, rgb, or var). Example: #1f1f1f",
          "value": "#1f1f1f"
        }
      ]
    }
  ],
  "filters": []
}
